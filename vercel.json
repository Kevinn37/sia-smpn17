{
    "version": 2,
    "builds": [
        {
            "src": "public/index.php",
            "use": "vercel-php@0.8.0"
        },
        {
            "src": "public/**",
            "use": "@vercel/static"
        }
    ],
    "routes": [
        {
            "src": "/(css|js|images|fonts|assets)/(.*)",
            "dest": "public/$1/$2"
        },
        {
            "src": "/(.*)",
            "dest": "public/index.php"
        }
    ],
    "env": {
        "APP_ENV": "production",
        "APP_DEBUG": "true",
        "CACHE_STORE": "file",
        "QUEUE_CONNECTION": "sync",
        "SESSION_DRIVER": "file",
        "APP_CONFIG_CACHE": "/tmp/config.php",
        "SERVICES_MANIFEST": "/tmp/services.php",
        "PACKAGES_MANIFEST": "/tmp/packages.php"
    }
}
